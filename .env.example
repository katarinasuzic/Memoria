# Supabase credentials — copy this file to `.env` and fill in your values.
# Find these in your Supabase project: Settings → API.
# These are exposed to the client (Expo inlines EXPO_PUBLIC_* at build time),
# so only use the public anon key here — never the service_role key.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
